{
  "name": "luma-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.18.0",
    "npm": ">=10"
  },
  "scripts": {
    "login": "node --experimental-strip-types --no-warnings src/login.ts",
    "login:x": "node --experimental-strip-types --no-warnings src/login.ts https://x.com/login",
    "dev": "node --watch --experimental-strip-types --no-warnings src/server.ts",
    "start": "node --experimental-strip-types --no-warnings src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^2.4.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "openai": "^6.38.0",
    "playwright": "^1.49.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0"
  }
}
