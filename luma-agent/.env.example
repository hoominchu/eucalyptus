# Provide either OPENAI_API_KEY or ANTHROPIC_API_KEY. If both are set, the
# STAGEHAND_MODEL value picks which client is used (openai/* or anthropic/*).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Required: shared secret the webhook caller must send as `Authorization: Bearer <token>`.
WEBHOOK_TOKEN=

# Port the webhook server listens on. Default 8780.
PORT=8780

# Directory holding the persistent Chromium profile (cookies, storage).
# Run `npm run login` once to populate it.
USER_DATA_DIR=./browser-profile

# Set to "false" to launch a visible browser during scrapes (useful for debugging).
HEADLESS=true

# Stagehand model. Recommended: gpt-4o (OpenAI) or claude-sonnet-4-5 (Anthropic).
# The cheaper gpt-4.1-mini struggles on Luma's guest dialog.
STAGEHAND_MODEL=gpt-4o
